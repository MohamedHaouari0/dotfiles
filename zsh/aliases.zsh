# Better tools
alias ls='eza --icons=always'
alias ll='eza -lah --icons=always'
alias la='eza -a --icons=always'
alias tree='eza --tree --icons=always'

#Better cat
alias cat='bat'

#Better Search
alias rg='rg'
alias rgrep='rg'
alias find='fd'

#Better Clear
alias c='clear'

# Navigation
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

# Git
alias gs='git status'
alias ga='git add'
alias gc='git commit'
alias gp='git push'
alias gpl='git pull'
alias gd='git diff'
alias gco='git checkout'

# openSUSE
alias update='sudo zypper dup'
alias install='sudo zypper install'
alias remove='sudo zypper remove'

# Editor
alias v='nvim'
alias nv='nvim'

# System
alias ports='ss -tulpn'
alias df='df -h'
alias free='free -h'
alias ps='procs'
alias top='btop'
alias du='dust'
alias lg='lazygit'
alias fm='yazi'

# Fastfetch
alias cls='clear && fastfetch'



