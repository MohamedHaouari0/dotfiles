#!/usr/bin/env bash

########################################
# Constants
########################################

readonly PROJECTS_DIR="$HOME/Projects"

########################################
# Variables
########################################

PROJECT_NAME=""
PROJECT_PATH=""

########################################
# Helper Functions
########################################

usage() {
cat << EOF
Usage:
    dev <project>

Example:
    dev minishell
    dev webserv
EOF
}

error() {
    echo "Error: $*" >&2
}

########################################
# Core Functions
########################################

parse_arguments() {

    if [[ $# -ne 1 ]]; then
        error "Expected exactly one project name."
        usage
        return 1
    fi

    PROJECT_NAME="$1"

    return 0
}

find_project() {

    PROJECT_PATH=$(find "$PROJECTS_DIR" \
        -type d \
        -name "$PROJECT_NAME" \
        2>/dev/null \
        | head -n1)

    if [[ -z "$PROJECT_PATH" ]]; then
        error "Project '$PROJECT_NAME' not found."
        return 1
    fi

    return 0
}

session_exists() {

    tmux has-session -t "$PROJECT_NAME" 2>/dev/null
}

create_session() {

    tmux new-session \
        -ds "$PROJECT_NAME" \
        -c "$PROJECT_PATH"
}

attach_session() {

    tmux attach-session -t "$PROJECT_NAME"
}

switch_session() {

    tmux switch-client -t "$PROJECT_NAME"
}

########################################
# Main
########################################

main() {

    parse_arguments "$@" || exit 1

    find_project || exit 1

    if ! session_exists; then
        create_session
    fi

    if [[ -n "$TMUX" ]]; then
        switch_session
    else
        attach_session
    fi
}

main "$@"
