[alias]
    s = status -sb

    a = add .

    aa = add -A

    c = commit

    cm = commit -m

    ca = commit --amend

    p = push

    pl = pull

    f = fetch

    co = checkout

    sw = switch

    b = branch

    bd = branch -d

    lg = log --graph --decorate --oneline --all

    last = log -1 HEAD

    st = stash

    pop = stash pop

    undo = reset --soft HEAD~1

    unstage = restore --staged .
